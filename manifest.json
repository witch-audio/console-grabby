{
  "manifest_version": 3,
  "name": "Console Grabby",
  "version": "1.1.0",
  "description": "Grab console logs from any tab and copy them in one click.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "activeTab",
    "debugger",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ]
}
